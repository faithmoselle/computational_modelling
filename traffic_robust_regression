import numpy as np
import matplotlib.pyplot as plt
from sklearn.linear_model import LinearRegression, RANSACRegressor
from sklearn.metrics import r2_score

print("=" * 60)
print("MIDTERM SUMMATIVE ASSESSMENT")
print("=" * 60)

# ============================================================================
# PART 1: TRAFFIC FLOW MODELING WITH GREENSHIELDS MODEL
# ============================================================================
"""
Original Greenshields Model: Maximum flow occurs at the optimal density (roughly half of jam density), achieving ~3,750 cars/hour at 75 cars/km.
With Traffic Lights (40% slowdown): The maximum flow is reduced to a lower value, and the optimal density shifts, reflecting the impact of traffic control.
"""
print("\n--- PART 1: Traffic Flow with and without Traffic Lights ---")

# Define Greenshields model constants
v_free = 100   # Free-flow speed (km/h) when density = 0
k_jam = 150    # Jam density (cars/km) when speed = 0

# Original Greenshields speed-density model
def speed_density(k):
    """Linear speed-density relationship (Greenshields Model)."""
    return v_free * (1 - k / k_jam)

# Adjusted model to simulate traffic lights effect
def speed_density_with_lights(k):
    """
    Modified speed-density model with traffic light impact.
    When density exceeds 80 cars/km, speed is reduced by 40%.
    This simulates congestion from traffic light cycles.
    """
    v = v_free * (1 - k / k_jam)
    v_adjusted = np.where(k > 80, v * 0.6, v)  # Reduce speed by 40% if density > 80
    return v_adjusted

# Generate density values and compute speeds and flow
k_values = np.linspace(0, 150, 200)          # Density range (0 to jam density)
v_original = speed_density(k_values)         # Speeds for original model
v_adjusted = speed_density_with_lights(k_values)  # Speeds with traffic lights

# Flow = density × speed (fundamental traffic equation)
q_original = k_values * v_original
q_adjusted = k_values * v_adjusted

# Find maximum flow (road capacity) for both models
max_flow_orig = np.max(q_original)
best_density_orig = k_values[np.argmax(q_original)]

max_flow_adj = np.max(q_adjusted)
best_density_adj = k_values[np.argmax(q_adjusted)]

print(f"Original Model - Max Flow: {max_flow_orig:.0f} cars/hour at {best_density_orig:.0f} cars/km")
print(f"With Traffic Lights - Max Flow: {max_flow_adj:.0f} cars/hour at {best_density_adj:.0f} cars/km")

# Plot both curves
plt.figure(figsize=(10, 6))
plt.plot(k_values, q_original, 'b-', label="Original Flow–Density")
plt.plot(k_values, q_adjusted, 'r--', label="With Traffic Lights (40% slowdown)")
plt.xlabel("Density (cars/km)")
plt.ylabel("Flow (cars/hour)")
plt.title("Traffic Flow Model: Impact of Traffic Lights on Road Capacity")
plt.legend()
plt.grid(True, alpha=0.3)

# Annotate maximum flow points
plt.annotate(f"Max Flow: {max_flow_orig:.0f}\nat {best_density_orig:.0f} cars/km",
             xy=(best_density_orig, max_flow_orig),
             xytext=(best_density_orig+5, max_flow_orig+200),
             arrowprops=dict(arrowstyle="->", color='blue'))
plt.annotate(f"Adj. Max Flow: {max_flow_adj:.0f}\nat {best_density_adj:.0f} cars/km",
             xy=(best_density_adj, max_flow_adj),
             xytext=(best_density_adj-40, max_flow_adj-500),
             arrowprops=dict(arrowstyle="->", color='red'))

plt.tight_layout()
plt.show()

# ============================================================================
# PART 2: ROBUST REGRESSION (LINEAR vs RANSAC with Outliers)
# ============================================================================
"""
Linear Regression: The model's coefficients are heavily influenced by outliers (e.g., slope might drop significantly). The R² score is much lower.
RANSAC Regression: The model ignores outliers and correctly identifies the underlying trend (slope close to the true value of 2.5). The R² score (on all data) is still affected by the outliers, but the model parameters are much more reliable.
"""
print("\n" + "=" * 60)
print("--- PART 2: Comparing Linear and Robust Regression ---")

# Step 1: Generate a clean linear dataset with noise
np.random.seed(42)
X = np.linspace(0, 100, 100).reshape(-1, 1)  # 100 points from 0 to 100
y = 2.5 * X.ravel() + 20 + np.random.normal(0, 10, X.shape[0])  # y = 2.5x + 20 + noise

# Step 2: Add 3 extreme outliers to simulate real-world anomalies
X_outliers = np.array([[10], [50], [90]])
y_outliers = np.array([250, -50, 400])  # High and low outliers
X_combined = np.vstack((X, X_outliers))
y_combined = np.concatenate((y, y_outliers))

print(f"\nDataset shape: {X_combined.shape[0]} points (including {len(X_outliers)} outliers)")

# Step 3: Fit models
# Standard Linear Regression (sensitive to outliers)
lr = LinearRegression()
lr.fit(X_combined, y_combined)
y_pred_lr = lr.predict(X_combined)

# RANSAC Regression (robust to outliers)
ransac = RANSACRegressor(random_state=42)
ransac.fit(X_combined, y_combined)
y_pred_ransac = ransac.predict(X_combined)

# Step 4: Compare results
print("\n--- Model Performance Comparison ---")
print(f"Linear Regression R²: {r2_score(y_combined, y_pred_lr):.3f}")
print(f"RANSAC Regression R²: {r2_score(y_combined, y_pred_ransac):.3f}")
print(f"Linear slope: {lr.coef_[0]:.2f}")
print(f"RANSAC slope: {ransac.estimator_.coef_[0]:.2f}")

# Step 5: Visualize results
plt.figure(figsize=(10, 6))
plt.scatter(X_combined, y_combined, color='gray', alpha=0.6, label='Data Points')
plt.plot(X_combined, y_pred_lr, 'r-', label=f'Linear (Slope: {lr.coef_[0]:.2f})')
plt.plot(X_combined, y_pred_ransac, 'g-', label=f'RANSAC (Slope: {ransac.estimator_.coef_[0]:.2f})')
plt.xlabel('Advertising Budget (k$)')
plt.ylabel('Sales (k units)')
plt.title('Regression Comparison: Linear vs RANSAC with Outliers')
plt.legend()
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.show()

print("\n" + "=" * 60)
print("KEY INSIGHTS:")
print("-" * 60)
print("1. Traffic Lights reduce road capacity by ~40% during high-density periods.")
print("2. RANSAC regression is more robust to outliers than standard Linear Regression.")
print("3. Outliers can severely skew standard regression, leading to unreliable predictions.")
print("=" * 60)
